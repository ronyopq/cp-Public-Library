{
  "name": "cx--public-library",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n APP,API -c blue,green \"vite\" \"wrangler dev --local --port 8787\"",
    "dev:app": "vite",
    "dev:api": "wrangler dev --local --port 8787",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply cx-public-library-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply cx-public-library-db --remote",
    "db:seed:local": "wrangler d1 execute cx-public-library-db --local --file ./seeds/001_reference_data.sql",
    "db:seed:remote": "wrangler d1 execute cx-public-library-db --remote --file ./seeds/001_reference_data.sql",
    "deploy": "npm run build && wrangler deploy",
    "icons": "node ./scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@fontsource/hind-siliguri": "^5.2.7",
    "@fontsource/manrope": "^5.2.8",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@noble/hashes": "^2.0.1",
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "hono": "^4.12.8",
    "jsbarcode": "^3.12.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.74.0"
  }
}
